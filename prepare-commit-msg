#!/bin/bash

# $1 = commit message file, $2 = source
# Skip whenever a meaningful message already exists:
#   - message/merge/squash/commit: always (from -m, -F, merge, squash, -c, --amend)
#   - template: only if the template file has real (non-comment, non-whitespace) content;
#     an empty template like SourceTree's default ~/.stCommitMsg should fall through.
case "$2" in
    message|merge|squash|commit)
        exit 0
        ;;
    template)
        if grep -v '^#' "$1" | grep -q '[^[:space:]]'; then
            exit 0
        fi
        ;;
esac

DIFF=$(git diff --cached)
if [ -z "$DIFF" ]; then
    exit 0
fi

MSG=$(echo "$DIFF" | claude -p "
Write a conventional commit message.

Rules:
- type: feat/fix/chore/refactor/docs/test
- max 72 chars
- no explanation
- output only message
" 2>/dev/null)

# Fallback: if claude failed or returned empty, leave the default template untouched
if [ -n "$MSG" ]; then
    echo "$MSG" > "$1"
else
    echo "prepare-commit-msg: claude returned empty; falling back to default template" >&2
fi
